{
  "name": "novel-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:server": "pnpm --filter @novel-analyzer/core build && pnpm --filter @novel-analyzer/server dev",
    "dev:web": "pnpm --filter @novel-analyzer/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm --filter @novel-analyzer/core build && pnpm -r typecheck",
    "test": "pnpm --filter @novel-analyzer/core test"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
